# DiscoBall environment configuration
# Copy this file to `.env` and adjust as needed. The defaults match the
# docker-compose Postgres service, so a fresh clone works with no edits.

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgres://discoball:discoball@localhost:5432/discoball

# --- Auth.js ------------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=dev-only-change-me-please
AUTH_URL=http://localhost:3000

# Optional Google OAuth (leave blank to use email/password only)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Document rendering (PDF) -------------------------------------------------
# Optional. When set, DOCX is converted to PDF via a Gotenberg/LibreOffice
# service. Leave blank in early phases to keep DOCX-only generation.
PDF_RENDER_URL=

# --- App ----------------------------------------------------------------------
NODE_ENV=development
